# Copy this file to .env.local and fill in real values.
# .env.local is gitignored by default in Next.js — never commit real keys.

# Required for requirement extraction (AI fallback) and STAR response generation.
ANTHROPIC_API_KEY=sk-ant-...

# Required for real payment collection via Stripe Checkout.
# Get this from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Optional: only needed once you add pages/api/webhook.js to verify payments
# server-side instead of trusting the success_url redirect.
# STRIPE_WEBHOOK_SECRET=whsec_...
